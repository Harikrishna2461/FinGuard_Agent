# Copy this file to ai_system/.env and fill in your values before running docker-compose.
OPENAI_API_KEY=sk-...
# gpt-4o-mini (default) works for most usage; set to an o-series model (e.g. o4-mini)
# if you want extended reasoning and have access.
OPENAI_MODEL=gpt-4o-mini
OPENAI_REASONING_EFFORT=medium
